{
  "expo": {
    "name": "LocalStore",
    "slug": "localstore",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "localstore",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image-picker",
      "expo-image",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.raja.localstore",
      "associatedDomains": ["applinks:localstore.app"]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.raja.localstore",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "localstore.app",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "52d0c1e4-b023-4322-8426-a078b32f403a"
      }
    },
    "owner": "rajamohanrdy",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/52d0c1e4-b023-4322-8426-a078b32f403a"
    }
  }
}
